{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "viceunf/footer-cta",
  "version": "1.0.0",
  "title": "ViceUnf - Footer CTA",
  "category": "viceunf-blocks",
  "icon": "megaphone",
  "description": "Sección de cierre de página con llamado a la acción de alto impacto: título, subtítulo, botón grande y fondo de color configurable.",
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "buttonColor": {
      "type": "string",
      "default": ""
    },
    "bgColor": {
      "type": "string",
      "default": "#0e1422"
    },
    "showLogos": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "textdomain": "viceunf",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
