{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "viceunf/timeline-step",
  "version": "1.0.0",
  "title": "ViceUnf - Paso del Timeline",
  "category": "viceunf-blocks",
  "icon": "marker",
  "description": "Paso individual del timeline con número, título, descripción e ícono opcional. Solo para usar dentro de Visual Timeline.",
  "parent": [
    "viceunf/visual-timeline"
  ],
  "attributes": {
    "stepNumber": {
      "type": "number",
      "default": 1
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "icon": {
      "type": "string",
      "default": ""
    },
    "accentColor": {
      "type": "string",
      "default": "#ff4700"
    }
  },
  "supports": {
    "html": false,
    "reusable": false
  },
  "textdomain": "viceunf",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}