{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "viceunf/event-schedule",
  "version": "1.0.0",
  "title": "ViceUnf - Cronograma de Eventos",
  "category": "viceunf-blocks",
  "icon": "calendar-alt",
  "description": "Grid de tarjetas estilo 'libreta con anillas' para mostrar sesiones, fechas y horarios de un programa o evento.",
  "attributes": {
    "columns": {
      "type": "number",
      "default": 3
    },
    "sectionTitle": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "viceunf",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}