{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "viceunf/logo-partners",
  "version": "1.0.0",
  "title": "ViceUnf - Logos de Aliados",
  "category": "viceunf-blocks",
  "icon": "awards",
  "description": "Muestra logos de socios o aliados institucionales. Lee los datos desde el CPT Socio del plugin viceunf-core (modo automático) o desde una lista manual.",
  "attributes": {
    "sectionTitle": {
      "type": "string",
      "default": ""
    },
    "displayMode": {
      "type": "string",
      "default": "static"
    },
    "grayscaleDefault": {
      "type": "boolean",
      "default": true
    },
    "source": {
      "type": "string",
      "default": "cpt"
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "viceunf",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}