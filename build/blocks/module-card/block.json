{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "viceunf/module-card",
  "version": "1.0.0",
  "title": "ViceUnf - Tarjeta de Módulo",
  "category": "viceunf-blocks",
  "icon": "screenoptions",
  "description": "Módulo individual con etiqueta, ícono con indicador de progreso semicircular y lista de puntos clave. Solo para usar dentro de Program Modules.",
  "parent": [
    "viceunf/program-modules"
  ],
  "attributes": {
    "label": {
      "type": "string",
      "default": ""
    },
    "icon": {
      "type": "string",
      "default": "fa-solid fa-book"
    },
    "progressPercent": {
      "type": "number",
      "default": 75
    },
    "bulletPoints": {
      "type": "array",
      "default": []
    },
    "cardColor": {
      "type": "string",
      "default": "#1e2a4a"
    }
  },
  "supports": {
    "html": false,
    "reusable": false
  },
  "textdomain": "viceunf",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}